{
  "name": "mushroom-map-root",
  "version": "0.1.0",
  "private": true,
  "description": "mushroom-map monorepo — web app, API service, and shared packages (design tokens, types, API client) for the interactive mushroom map of Leningrad Oblast",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @mushroom-map/web run dev",
    "build": "npm -ws --if-present run build",
    "typecheck": "npm -ws --if-present run typecheck",
    "lint": "npm -ws --if-present run lint",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  }
}
