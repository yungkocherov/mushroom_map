# Не таскаем ничего heavyweight в docker build context.
# Критично: data/ содержит ~3 GB tile/DEM/VK cache — в image их быть не должно.

.git
.venv
__pycache__
**/__pycache__
**/*.pyc
**/*.pyo

# Host-side node_modules (workspace + per-package) заменяется npm ci в образе.
node_modules
**/node_modules

# Данные (tiles, DEM, VK cache) — никогда не попадают в образ.
data

# Build artefacts
apps/web/dist
dist
build

# Local env / IDE
.env
.env.local
.vscode
.idea

# OS
.DS_Store
Thumbs.db
