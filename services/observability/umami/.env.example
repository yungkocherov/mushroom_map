# Copy to services/observability/umami/.env on the prod VM.

# 32+ bytes for cookie/JWT signing. Generate:
#   openssl rand -base64 32
APP_SECRET=REPLACE_ME

# Postgres role password (created manually; see README.md §1).
UMAMI_DB_PASSWORD=REPLACE_ME

# Optional: pin tracker filename so cross-domain doesn't leak data.
# Leave empty for default behavior.
TRACKER_SCRIPT_NAME=
