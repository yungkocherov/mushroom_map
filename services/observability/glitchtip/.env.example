# Copy to services/observability/glitchtip/.env on the prod VM and fill
# in real values. This file is gitignored as a wildcard (.env*) — do not
# commit secrets.

# Django secret — 50+ random bytes. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE_ME

# Postgres role password (created manually; see README.md §1).
GLITCHTIP_DB_PASSWORD=REPLACE_ME

# Public URL the GlitchTip web app assumes it lives at. Used in outgoing
# email links and SDK ingest config.
GLITCHTIP_DOMAIN=https://sentry.geobiom.ru

# Lock down the install — only one operator account.
ENABLE_USER_REGISTRATION=false
ENABLE_ORGANIZATION_CREATION=false

# Email settings (optional). consolemail:// dumps to journalctl; useful
# when there's no SMTP relay.
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=glitchtip@geobiom.ru
