# Caddy reverse-proxy для прод-VM.
#
# Архитектура:
#   Caddy на VM         → geobiom.ru     (статический фронт из /srv/web)
#                       → api.geobiom.ru (api + tiles)
#   - /api/*            → api:8000
#   - /tiles/*          → api:8000 (PMTiles range-requests)
#   - /health           → api:8000
#
# Cloudflare Pages удалён 2026-04-29: TSPU режет CF SNI, сайт не открывался
# из РФ без VPN. Фронт переехал на ту же VM, DNS geobiom.ru — grey-cloud
# (DNS only) → 178.253.43.136. R2 bucket тоже отключён, тайлы раздаёт
# api.geobiom.ru/tiles/* (см. блок ниже).
#
# Caddy сам управляет TLS через ACME — нужно только корректное A-запись
# {api,}geobiom.ru → IP VM до первого запроса.
#
# Email для ACME: подставится из CADDY_ACME_EMAIL env-переменной (см.
# /etc/default/caddy на VM или env_file в compose).

{
	# Глобальные опции — email Let's Encrypt'а ставится через CLI flag
	# или env. Не хардкодим тут чтобы не конфликтовало с локальным
	# тестом без TLS.
	email {$CADDY_ACME_EMAIL}

	# 2026-04-30: HTTP/1.1 only. После переезда TimeWeb→Oracle (новый IP
	# 79.76.53.170 в Стокгольме) браузеры из РФ без ВПН валились с
	# ERR_CONNECTION_RESET на загрузке assets через HTTP/2 multiplex.
	# Bash curl с HTTP/1.1 — 200 OK, проблема именно в h2/h3
	# fingerprint'е TSPU-фильтра. h1 без multiplexing'а проходит чисто.
	# Минус: каждый ассет = отдельный TCP — медленнее на parallel-load,
	# но ситуация «работает vs не работает». Когда (если) Oracle IP
	# «обкатается» — можно вернуть h2.
	servers {
		protocols h1
	}
}

# api-домен — единственный, который Caddy слушает на этой VM.
# Подставь свой через env CADDY_API_HOST=api.example.org.
{$CADDY_API_HOST} {
	# Security headers — уровня api.* эндпоинта (фронт на CF Pages
	# обычно сам добавляет CSP/X-Frame-Options и т.п.). HSTS — главное:
	# гарантирует браузеру что клиент-API контракт всегда HTTPS.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "no-referrer"
		# api отдаёт только JSON / pmtiles — никакого встраивания.
		Permissions-Policy        "interest-cohort=()"
		# Заголовок Server: Caddy раскрывает версию — убираем.
		-Server
	}

	# Срезаем входящий X-Forwarded-For ДО reverse_proxy: иначе клиент
	# может вписать любой IP в наши логи / `user_refresh_token.client_ip`.
	# Caddy всё равно добавляет свой XFF при проксировании.
	request_header -X-Forwarded-For

	# Сжатие — text/json/yaml, не трогаем PMTiles (он уже бинарь, gzip
	# съест CPU и сломает Range-семантику).
	encode {
		gzip
		match {
			header Content-Type application/json*
			header Content-Type text/*
		}
	}

	# Здоровье. /health — liveness без БД (просто что api жив).
	# /api/healthz пингует Postgres и возвращает 503 если БД недоступна —
	# именно его стоит подключать в uptime-мониторинг. /api/healthz
	# проксируется через общий handle /api/* ниже, отдельный блок не нужен.
	handle /health {
		reverse_proxy api:8000
	}

	# PMTiles — Range-requests обязательны. Caddy проксирует Range:
	# заголовок прозрачно, но мы отключаем буферизацию явно.
	handle /tiles/* {
		reverse_proxy api:8000 {
			flush_interval -1
			# Включаем accept-ranges:bytes, если апстрим забыл.
			header_down Accept-Ranges bytes
		}
		# Cache-friendly: tile-файлы immutable по name+hash.
		header Cache-Control "public, max-age=86400, immutable"
	}

	# Все API-вызовы.
	handle /api/* {
		reverse_proxy api:8000 {
			flush_interval -1
		}
		# CORS preflight отвечает сам FastAPI (CORSMiddleware), Caddy не
		# переопределяет.
	}

	# Всё остальное — 404, чтобы не отдавать пустой Caddy-баннер.
	handle {
		respond "Not Found" 404
	}

	# Логи в JSON, удобно для journalctl/loki.
	log {
		output stdout
		format json
	}
}

# Web-фронт. Раздаёт собранный Vite SPA из /srv/web. CADDY_WEB_HOST
# подставляется из env (geobiom.ru в проде). www-вариант редиректит
# на канон — Vite build один.
{$CADDY_WEB_HOST} {
	root * /srv/web

	# Сжатие для html/js/css/json. SVG тоже выигрывает.
	encode gzip

	# Long-cache для immutable-ассетов из Vite (имя содержит content-hash).
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# index.html и всё остальное — короткий кэш, чтобы новые релизы
	# подхватывались быстро.
	header Cache-Control "public, max-age=300, must-revalidate"

	# Security headers. CSP не ставим тут — у фронта есть inline-стили
	# Vite/MapLibre, рискованно сломать без аудита; сделаем отдельным шагом.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "interest-cohort=()"
		-Server
	}

	# SPA fallback — любой роут, который не файл, отдаёт index.html.
	# try_files перед file_server обязательно: иначе 404 на /spots, /species.
	try_files {path} /index.html
	file_server

	log {
		output stdout
		format json
	}
}

www.{$CADDY_WEB_HOST} {
	redir https://{$CADDY_WEB_HOST}{uri} 308
}

# GlitchTip self-hosted error tracking. Контейнер биндится только на
# loopback (127.0.0.1:8001 в docker-compose), сюда заходим строго через
# Caddy. Хост подставляется из CADDY_SENTRY_HOST env (sentry.geobiom.ru
# в проде). Дефолт `sentry.unused.local` нужен чтобы Caddyfile парсился
# когда переменная не задана (TimeWeb env не имеет наблюдательного
# стека) — внешний трафик на этот dummy-домен не приходит.
{$CADDY_SENTRY_HOST:sentry.unused.local} {
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "no-referrer"
		-Server
	}
	reverse_proxy glitchtip-web:8000 {
		flush_interval -1
	}
	log {
		output stdout
		format json
	}
}

# Umami self-hosted analytics. Та же модель — контейнер на loopback,
# Caddy на 443 → 127.0.0.1:8002 → umami:3000. Дефолт-домен — см.
# комментарий выше про CADDY_SENTRY_HOST.
{$CADDY_UMAMI_HOST:analytics.unused.local} {
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "no-referrer"
		-Server
	}
	reverse_proxy umami:3000 {
		flush_interval -1
	}
	log {
		output stdout
		format json
	}
}
