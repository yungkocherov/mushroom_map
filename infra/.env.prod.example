# ─── Production env для docker-compose.prod.yml ────────────────────────
# Скопировать как `.env.prod` рядом с docker-compose.prod.yml на VM
# и заполнить. Все секреты — длинные (256+ бит). Не коммитим.

# ─── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=mushroom
POSTGRES_PASSWORD=__GENERATE_LONG_RANDOM_STRING__
POSTGRES_DB=mushroom_map

# ─── API runtime ───────────────────────────────────────────────────────
# Workers — 2 на 4-core ARM хватает; повышаем по реальному p95 latency.
UVICORN_WORKERS=2

# Image — берём с GHCR из последнего деплоя; для отката указать tag-sha.
API_IMAGE=ghcr.io/yungkocherov/mushroom-map-api:latest

# CORS — список ориджинов через запятую без пробелов. Перечисляй явно
# (FastAPI CORSMiddleware не любит wildcards с allow_credentials=True).
# После переезда с CF Pages фронт живёт на той же VM, но на отдельном
# хосте (geobiom.ru ↔ api.geobiom.ru), CORS всё ещё нужен.
API_CORS_ORIGINS=https://geobiom.ru,https://www.geobiom.ru

# ─── Auth / JWT ────────────────────────────────────────────────────────
# 64+ символов, рандом. python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=__GENERATE_LONG_RANDOM_STRING__
COOKIE_SECURE=true

# ─── Yandex ID ─────────────────────────────────────────────────────────
# Регистрация: https://oauth.yandex.ru/client/new (callback ниже).
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://api.example.org/api/auth/yandex/callback

# Куда редиректит фронт после OAuth.
FRONTEND_AUTH_COMPLETE_URL=https://example.org/auth/complete
FRONTEND_AUTH_ERROR_URL=https://example.org/auth/error

# ─── Caddy ─────────────────────────────────────────────────────────────
# Хосты, на которых Caddy слушает + email для Let's Encrypt.
CADDY_API_HOST=api.geobiom.ru
CADDY_WEB_HOST=geobiom.ru
CADDY_ACME_EMAIL=admin@geobiom.ru

# ─── Web mount ─────────────────────────────────────────────────────────
# Куда заливается собранный Vite SPA (rsync из deploy-web.yml).
# Caddy раздаёт этот каталог на CADDY_WEB_HOST. Если меняешь — синхронно
# правь docker-compose.prod.yml.
WEB_HOST_PATH=/srv/web

# ─── Tile/terrain mounts ───────────────────────────────────────────────
# Пути на ХОСТЕ — куда заранее загружены *.pmtiles + DEM-растры.
# Если меняешь — синхронно правь docker-compose.prod.yml.
TILES_HOST_PATH=/srv/mushroom-map/tiles
TERRAIN_HOST_PATH=/srv/mushroom-map/terrain
