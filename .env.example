# ─── Database ─────────────────────────────────────────────
POSTGRES_USER=mushroom
POSTGRES_PASSWORD=mushroom_dev
POSTGRES_DB=mushroom_map
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://mushroom:mushroom_dev@localhost:5432/mushroom_map

# ─── VK API (для сбора постов) ────────────────────────────
VK_TOKEN=

# ─── Overpass (OSM) ───────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ─── API service ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# ─── Web ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── Auth / JWT ───────────────────────────────────────────
# Длинная случайная строка. Одновременно подписывает access-JWT,
# короткоживущие OAuth-state и выступает pepper'ом для хэша refresh-токенов.
# СМЕНА этого секрета разлогинит всех пользователей — это by design.
JWT_SECRET=change-me-in-production-a-long-random-string
# Cookie.Secure=true обязательна в проде (https). В dev — false.
COOKIE_SECURE=false

# ─── Yandex ID OAuth ──────────────────────────────────────
# Регистрация приложения: https://oauth.yandex.ru/client/new
#   scopes: login:email login:info login:avatar
#   callback URI: http://localhost:8000/api/auth/yandex/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8000/api/auth/yandex/callback
# URL'ы фронта куда редиректит OAuth callback после выдачи cookie.
FRONTEND_AUTH_COMPLETE_URL=http://localhost:5173/auth/complete
FRONTEND_AUTH_ERROR_URL=http://localhost:5173/auth/error
