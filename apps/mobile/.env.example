# Geobiom Mobile environment vars (for `expo start` / EAS Build).
#
# Copy to `.env` (gitignored). EXPO_PUBLIC_* vars are inlined into the
# JS bundle at build time — никаких секретов сюда. Реальные секреты
# (Yandex client_secret) живут только на backend.

# Yandex OAuth: client_id мобильного приложения с oauth.yandex.ru
# (тип «Мобильные приложения», redirect URI = geobiom://auth/callback).
# Без этого Settings → «Войти через Яндекс» покажет alert «OAuth не настроен».
EXPO_PUBLIC_YANDEX_MOBILE_CLIENT_ID=

# API host. Default — production. Для dev можно ткнуть на http://10.0.2.2:8000
# (Android emulator alias for host machine localhost) если поднят локальный
# uvicorn. Реальный токен exchange через /api/mobile/auth/yandex
# поэтому нужен валидный Yandex client_id даже в dev.
# EXPO_PUBLIC_API_BASE_URL=https://api.geobiom.ru

# Sentry / GlitchTip DSN — Phase 4 polish. Empty = no-op.
# EXPO_PUBLIC_SENTRY_DSN=
